<script>
        // Script tải Header/Footer (Giữ nguyên)
        function loadComponent(url, placeholderId, callback) {
             fetch(url)
                 .then(response => {
                     if (!response.ok) throw new Error(`Failed to load ${url}: ${response.statusText}`);
                     return response.text();
                 })
                 .then(data => {
                     const placeholder = document.getElementById(placeholderId);
                     if (placeholder) {
                         placeholder.innerHTML = data;
                         if (callback && typeof callback === 'function') {
                             setTimeout(callback, 0);
                         }
                     }
                 })
                 .catch(error => console.error(`Error loading component ${url}:`, error));
        }

        function applyLanguageIfReady() {
            if (typeof window.applyLanguage === 'function') {
                 window.applyLanguage(localStorage.getItem('preferredLanguage') || 'vi');
            } else {
                 console.warn('applyLanguage function not ready yet.');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            let headerLoaded = false;
            let footerLoaded = false;

            // Guard manual loading: skip if loadComponents.js will handle it or if component already injected
            (function guardLoadWithCallback(url, id, cb) {
                const placeholder = document.getElementById(id);
                if (!placeholder) return;
                if (window.loadAndInject || placeholder.querySelector('[data-component-src]')) {
                    console.info(`guardLoadWithCallback: skipping manual load for ${id}`);
                    if (typeof cb === 'function') cb();
                    return;
                }
                loadComponent(url, id, cb);
            })('header.html', 'header-placeholder', () => {
                if (typeof initializeMenu === 'function') initializeMenu();
                headerLoaded = true;
                applyLanguageIfReady();
            });

            (function guardLoadWithCallback(url, id, cb) {
                const placeholder = document.getElementById(id);
                if (!placeholder) return;
                if (window.loadAndInject || placeholder.querySelector('[data-component-src]')) {
                    console.info(`guardLoadWithCallback: skipping manual load for ${id}`);
                    if (typeof cb === 'function') cb();
                    return;
                }
                loadComponent(url, id, cb);
            })('footer.html', 'footer-placeholder', () => {
                 footerLoaded = true;
                 applyLanguageIfReady();
            });

            applyLanguageIfReady(); // Apply for static content
        });
    </script>;


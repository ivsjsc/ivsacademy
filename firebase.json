{
  "hosting": {
    "public": ".",
    "site": "ivsacademy",
    "ignore": [
      "firebase.json",
      "**/.*",
      "!**/.gitkeep",
      "**/node_modules/**",
      "server/**",
      "webapp/**",
      ".venv/**",
      "**/*.md",
      ".githooks/**"
    ],
    "rewrites": [
      {
        "source": "/api",
        "run": {
          "serviceId": "ivs-public-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "ivs-public-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/Pages/ivstech",
        "destination": "/Pages/ivstech.html"
      },
      {
        "source": "/Pages/ivstech/**",
        "destination": "/Pages/ivstech.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

{
  "hosting": {
    "public": ".",
    "site": "ivsacademy",
    "ignore": [
      "firebase.json",
      "**/.*",
      "!**/.gitkeep",
      "**/node_modules/**",
      "server/**",
      "webapp/**",
      ".venv/**",
      "**/*.md",
      ".githooks/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

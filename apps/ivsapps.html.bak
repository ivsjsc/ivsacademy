    </main>

    <div id="fab-container-placeholder"></div>
    <div id="footer-placeholder"></div>

    <!-- Load shared components and the language system (injects header, FAB, footer) -->
    <script src="/js/loadComponents.js" defer></script>
</body>
</html>

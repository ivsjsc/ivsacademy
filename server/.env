PORT=3000
CALLBACK_API_KEY=
CALLBACK_STATE=

# OAuth2 Configuration for Microsoft Entra
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TENANT_ID=
OAUTH_REDIRECT_URI=https://ivsacademy.edu.vn/auth/callback

# For server-side Graph lookup (client credentials)
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=

# XAI / third-party AI service API key (server-side only)
XAI_API_KEY=

# AI Proxy configuration
# Example using Google Generative Language API
# AI_BACKEND_URL=https://generativelanguage.googleapis.com/v1beta2/models/your-model:generate
# GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Alternatively, for OpenAI-compatible backends set:
# OPENAI_API_KEY=sk-...

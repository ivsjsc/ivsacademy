# Example .env.example (safe to commit) - copy to .env and fill values
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000

# Security
SESSION_SECRET=__REPLACE_WITH_RANDOM__
CALLBACK_API_KEY=__REPLACE_WITH_RANDOM__
CALLBACK_STATE=ivs_login_state

# OAuth (placeholders for Microsoft Entra or other providers)
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_CLIENT_ID=__REPLACE_WITH_CLIENT_ID__
OAUTH_CLIENT_SECRET=__REPLACE_WITH_CLIENT_SECRET__
OAUTH_TENANT_ID=

# For server-side Graph lookup (if needed)
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=

# AI (server-side only)
# Put production keys in vault / CI secrets - do not commit them here
GEMINI_API_KEY=__REPLACE_WITH_GEMINI_KEY__
OPENAI_API_KEY=__REPLACE_WITH_OPENAI_KEY__
XAI_API_KEY=

# AI Proxy configuration (if using a remote AI backend)
# AI_BACKEND_URL=https://generativelanguage.googleapis.com/v1beta2/models/your-model:generate

# Frontend → Backend Proxy for Vite
VITE_BACKEND_URL=http://localhost:3000

# CORS / Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://ivsacademy.edu.vn

# Database (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/ivs_db

# Monitoring / Logging
SENTRY_DSN=
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MIN=120

# Admin API Key (used to protect admin utilities like updating auth-config)
ADMIN_API_KEY=__REPLACE_WITH_ADMIN_API_KEY__

# Deployment
TRUST_PROXY=true

# Server Configuration
DEBUG=true

# Firebase Admin SDK
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_SDK_KEY={"type":"service_account",...}

# Google GenAI API
GOOGLE_API_KEY=AIzaSy...

# X.ai API
XAI_API_KEY=sk-...

# OpenAI API (if using OpenAI instead of X.ai)
OPENAI_API_KEY=sk-...

# Azure AD (for Graph lookup)
AAD_TENANT_ID=your-tenant-id
AAD_CLIENT_ID=your-client-id
AAD_CLIENT_SECRET=your-client-secret

# Email notifications (optional)
SENDGRID_API_KEY=SG...
ADMIN_EMAIL=admin@ivsacademy.edu.vn
SUPPORT_EMAIL=support@ivsacademy.edu.vn

# Database
DATABASE_URL=postgresql://user:pass@localhost/dbname

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:8000,https://ivsacademy.edu.vn

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Notes:
# - Copy this file to `.env` and set real secrets only on your dev machine or in the deployment environment.
# - For production, use cloud provider secret management and inject environment variables at deploy time.


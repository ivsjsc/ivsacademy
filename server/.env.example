# Copy this file to `.env` and fill real values on your machine or in deployment secrets.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000

# Security
SESSION_SECRET=__REPLACE_WITH_RANDOM__
CALLBACK_API_KEY=__REPLACE_WITH_RANDOM__
CALLBACK_STATE=ivs_login_state

# Firebase Admin SDK
# Get it from Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Paste the full JSON contents here as a single line.
FIREBASE_ADMIN_SDK_KEY={"type":"service_account","project_id":"..."}

# Newsletter email sender
# Use a verified sender/domain in Brevo.
NEWSLETTER_FROM_EMAIL=no-reply@ivsacademy.edu.vn

# Brevo transactional email
# Create in Brevo -> Settings -> API keys -> Generate a new API key.
BREVO_API_KEY=xkeysib-...

# Google Sheets webhook
# Create from Google Apps Script web app deployment and paste the /exec URL here.
NEWSLETTER_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/___/exec

# OAuth (optional)
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_CLIENT_ID=__REPLACE_WITH_CLIENT_ID__
OAUTH_CLIENT_SECRET=__REPLACE_WITH_CLIENT_SECRET__
OAUTH_TENANT_ID=

# Azure AD Graph lookup (optional)
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=

# AI (optional)
GEMINI_API_KEY=__REPLACE_WITH_GEMINI_KEY__
OPENAI_API_KEY=__REPLACE_WITH_OPENAI_KEY__
XAI_API_KEY=

# Frontend -> Backend proxy
VITE_BACKEND_URL=http://localhost:3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://ivsacademy.edu.vn
CORS_ORIGIN=http://localhost:8000,https://ivsacademy.edu.vn

# Database / monitoring
DATABASE_URL=postgresql://user:password@localhost:5432/ivs_db
SENTRY_DSN=
LOG_LEVEL=info
LOG_FORMAT=json

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MIN=120
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin / deployment
ADMIN_API_KEY=__REPLACE_WITH_ADMIN_API_KEY__
TRUST_PROXY=true
DEBUG=true

# Notes:
# - Do not commit `.env`.
# - If `FIREBASE_ADMIN_SDK_KEY` is not set, newsletter/contact can still accept form data,
#   but Firestore write will be skipped.

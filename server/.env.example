# Deployment environment template for IVS newsletter/contact server
# Copy to `.env` locally or set these as environment variables in production.

# App
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
BASE_URL=https://ivsacademy.edu.vn
TRUST_PROXY=true
DEBUG=false

# Security
SESSION_SECRET=__REPLACE_WITH_RANDOM_LONG_SECRET__
CALLBACK_API_KEY=__REPLACE_WITH_RANDOM__
CALLBACK_STATE=ivs_login_state
ADMIN_API_KEY=__REPLACE_WITH_ADMIN_API_KEY__

# Firebase Admin SDK
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_ADMIN_SDK_KEY={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Newsletter email
# Verify this sender/domain in Brevo first.
NEWSLETTER_FROM_EMAIL=no-reply@ivsacademy.edu.vn
BREVO_API_KEY=xkeysib-__REPLACE_WITH_BREVO_API_KEY__

# Google Sheets webhook
# Deploy the Apps Script as Web app and paste the /exec URL here.
NEWSLETTER_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/___/exec

# Optional sender fallback if BREVO_API_KEY is absent
SENDGRID_API_KEY=

# Optional OAuth / Graph
OAUTH_REDIRECT_URI=https://ivsacademy.edu.vn/auth/callback
OAUTH_CLIENT_ID=__REPLACE_WITH_CLIENT_ID__
OAUTH_CLIENT_SECRET=__REPLACE_WITH_CLIENT_SECRET__
OAUTH_TENANT_ID=
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=

# AI / proxy
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
VITE_BACKEND_URL=https://ivsacademy.edu.vn
CORS_ALLOWED_ORIGINS=https://ivsacademy.edu.vn,https://www.ivsacademy.edu.vn
CORS_ORIGIN=https://ivsacademy.edu.vn,https://www.ivsacademy.edu.vn

# Database / telemetry
DATABASE_URL=
SENTRY_DSN=
LOG_LEVEL=info
LOG_FORMAT=json

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MIN=120
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Notes:
# - Do not commit `.env`.
# - If `FIREBASE_ADMIN_SDK_KEY` is not set, the server can still accept forms,
#   but Firestore writes will be skipped.

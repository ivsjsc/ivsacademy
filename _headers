# Netlify headers file
# Security and performance headers for IVS Academy

/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com https://www.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com; frame-ancestors 'none';
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Cache static assets
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=86400

/audios/*
  Cache-Control: public, max-age=86400

/videos/*
  Cache-Control: public, max-age=86400

# HTML files - shorter cache
/*.html
  Cache-Control: public, max-age=3600

# Admin pages - no cache
/admin.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Analytics - no cache
/analytics.html
  Cache-Control: no-cache, no-store, must-revalidate

# Test suite - development only
/test-suite.html
  Cache-Control: no-cache, no-store, must-revalidate
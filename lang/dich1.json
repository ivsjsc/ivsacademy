  "partner_cross_industry_businesses_desc": "IVS mở rộng hợp tác với các doanh nghiệp đa ngành, hỗ trợ phát triển nguồn nhân lực chất lượng cao và các dự án có tác động xã hội tích cực.",
  "partner_cross_industry_businesses_title": "Các doanh nghiệp khác ngành",
  "partner_inspire_desc": "Strategic partner from the USA, collaborating with IVS to develop advanced education programs, bringing global inspiration and knowledge.",
  "partner_inspire_title": "The Power to Inspire (USA)",
  "partner_international_universities_desc": "IVS hợp tác với nhiều trường đại học uy tín trên thế giới, cung cấp các chương trình học bổng du học giá trị và cơ hội phát triển toàn diện cho học sinh, sinh viên.",
  "partner_international_universities_title": "Các trường Đại học Quốc tế",
  "partner_internationalcoop_cross_industry_businesses_desc": "IVS extends partnerships with diverse businesses, supporting the development of high-quality human resources and positive social impact projects.",
  "partner_internationalcoop_cross_industry_businesses_title": "Cross-Industry Businesses",
  "partner_internationalcoop_iu_english_academy_desc": "A partner organizing intensive English summer camp programs in the Philippines, helping students improve their proficiency and experience diverse cultures.",
  "partner_internationalcoop_iu_english_academy_title": "International Summer Camp: IU ENGLISH ACADEMY (Philippines)",
  "partner_internationalcoop_power_to_inspire_desc": "A strategic partner from the USA, collaborating with IVS to develop advanced educational programs that inspire the younger generation.",
  "partner_internationalcoop_power_to_inspire_title": "The Power to Inspire (USA)",
  "partner_internationalcoop_universities_desc": "IVS collaborates with many reputable universities worldwide, offering valuable study abroad scholarships and comprehensive development opportunities for students.",
  "partner_internationalcoop_universities_title": "International Universities",
  "partner_iu_english_academy_desc": "Đối tác tổ chức các chương trình trại hè tiếng Anh chuyên sâu tại Philippines, giúp học viên nâng cao trình độ và trải nghiệm văn hóa đa dạng.",
  "partner_iu_english_academy_title": "Trại hè Quốc tế: IU ENGLISH ACADEMY (Philippines)",
  "partner_kinderlink_desc": "Collaborating to develop an international standard preschool program, laying a solid foundation for future generations.",
  "partner_kinderlink_title": "Kinderlink25 Project",
  "partner_power_to_inspire_desc": "Đối tác chiến lược từ Hoa Kỳ, cùng IVS phát triển các chương trình giáo dục tiên tiến, truyền cảm hứng cho thế hệ trẻ.",
  "partner_power_to_inspire_title": "The Power to Inspire (Mỹ)",
  "partners_title": "Strategic Partners & International Affiliates",
  "philosophy_1_desc": "Building a separate learning path, respecting differences, applying Multiple Intelligences theory (Howard Gardner) to help students maximize their strengths.",
  "philosophy_1_title": "Personalized Education",
  "philosophy_2_desc": "Prioritizing Play-based and Project-based Learning methods, connecting knowledge with practice through projects, creative activities, and continuous practice.",
  "philosophy_2_title": "Experiential Learning",
  "philosophy_3_desc": "Selectively integrating international standards (NGSS, EYFS, Montessori...) on the foundation of preserving Vietnamese cultural identity, building global citizenship thinking.",
  "philosophy_3_title": "Global Integration",
  "philosophy_4_desc": "Focusing on training essential life skills (4Cs), critical thinking, problem solving, emotional intelligence (SEL), leadership and collaboration skills.",
  "philosophy_4_title": "Comprehensive Development",
  "philosophy_5_desc": "Appropriately applying AI, VR/AR, Gamification to personalize the learning path, enhance interest and knowledge acquisition effectiveness.",
  "philosophy_5_title": "Educational Technology",
  "philosophy_6_desc": "Description of the new pillar to be added later.",
  "philosophy_6_title": "New pillar",
  "philosophy_integrate_desc": "IVS brings a tight connection between technology platforms, educational programs, and practical needs, creating a synchronized, efficient operational system that delivers superior value to students, partners, and the community. We continuously innovate to optimize learning and management experiences.",
  "philosophy_integrate_description": "We build a comprehensive educational ecosystem, connecting advanced methodologies, modern technology, and multicultural knowledge to optimize the learning experience.",
  "philosophy_integrate_heading": "Integrate",
  "philosophy_integrate_initial": "I",
  "philosophy_integrate_title": "Integrate",
  "philosophy_synergy_desc": "The combined strength of organizations, individuals, and the community at IVS creates a powerful synergy, fostering sustainable and long-term development. We build an educational ecosystem where all components collaborate, share values, and together reach new heights in shaping the future.",
  "philosophy_synergy_description": "We believe in the power of collaboration: between students and teachers, families and schools, technology and pedagogy, creating a sustainable and effective learning community.",
  "philosophy_synergy_heading": "Synergy",
  "philosophy_synergy_initial": "S",
  "philosophy_synergy_title": "Synergy",
  "philosophy_title": "Core Philosophy: I-V-S",
  "philosophy_vision_desc": "IVS is not just about providing educational services; it pioneers in shaping the future of learning. We develop advanced training programs, applying modern technology to unlock comprehensive development opportunities, preparing students for the challenges of the 21st century.",
  "philosophy_vision_description": "IVS envisions an educational future where each individual maximizes their potential, equipped not only with knowledge but also with life skills and critical thinking for global integration.",
  "philosophy_vision_heading": "Vision",
  "philosophy_vision_initial": "V",
  "philosophy_vision_title": "Vision",

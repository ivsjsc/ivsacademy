  "pillar_education_tagline": "Elevating knowledge, creating global citizens.",
  "pillar_education_title": "Education & Training",
  "pillar_hr_desc_long": "We understand that people are the core element. IVS offers high-quality foreign teacher supply services, pedagogical training, and professional personnel development.",

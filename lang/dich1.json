  "non_profit_children_support_desc": "IVS JSC is committed to providing courses, materials, and scholarships for disadvantaged children, helping them access quality education and have opportunities for comprehensive development.",
  "non_profit_children_support_title": "Educational Support Program for Disadvantaged Children",
  "non_profit_cta_button": "Contact for Collaboration",
  "non_profit_cta_desc": "We always welcome the participation and contributions of like-minded individuals and organizations. Join IVS JSC in building a strong community and a brighter future.",
  "non_profit_cta_title": "Together, IVS Shapes a Brighter Future",
  "non_profit_cultural_exchange_desc": "Expanding the English Club into a multicultural and language exchange platform. We pair Vietnamese students with international students to practice languages, explore cultures, and build cross-border friendships.",
  "non_profit_cultural_exchange_info": "Regular exchange sessions will be announced on our fanpage and website.",
  "non_profit_cultural_exchange_title": "Cultural Exchange & Language Buddy Program",
  "non_profit_english_club_desc": "A free English club for all ages, helping to improve communication skills, expand cultural knowledge, and build confidence in an international environment. Regular sessions with native teachers and lively interactive activities.",
  "non_profit_english_club_title": "IVS English Club",
  "non_profit_environmental_desc": "Organizing volunteer activities to protect the environment, raise community awareness about climate change and sustainable development.",
  "non_profit_environmental_title": "Environmental Protection",
  "non_profit_global_citizen_workshop_desc": "An intensive workshop series designed to equip the younger generation with the essential skills and mindset to become responsible global citizens. Topics include critical thinking, cross-cultural problem-solving, digital ethics, and sustainable development.",
  "non_profit_global_citizen_workshop_info": "Detailed schedule and speaker information will be updated soon.",
  "non_profit_global_citizen_workshop_title": "Global Citizen Workshop",
  "non_profit_global_education_title": "Global Education & Integration: New Initiatives",
  "non_profit_global_mentorship_desc": "Connecting Vietnamese students with mentors who are experts, international students, or foreigners experienced in global fields. The program provides academic and career guidance, along with essential skills for success on the international stage.",
  "non_profit_global_mentorship_info": "Register to participate or become a mentor via our Contact page.",
  "non_profit_global_mentorship_title": "IVS Global Mentorship Program",
  "non_profit_hero_subtitle": "IVS JSC: Building Sustainable Values for the Community",
  "non_profit_hero_title": "Non-profit & Community Activities",
  "non_profit_impact_desc": "We are proud of our contributions and continuously strive to expand our positive influence on the community. Below are some notable achievements and inspiring stories from IVS JSC's projects.",
  "non_profit_impact_metric_1_label": "English Club Participants",
  "non_profit_impact_metric_1_value": "500+",
  "non_profit_impact_metric_2_label": "Scholarships & Educational Support",
  "non_profit_impact_metric_2_value": "100+",
  "non_profit_impact_metric_3_label": "NGO & International Partners",
  "non_profit_impact_metric_3_value": "10+",
  "non_profit_impact_quote": "\"IVS English Club has helped me gain much more confidence when communicating with foreigners. I not only learned English but also explored various cultures.\"",
  "non_profit_impact_quote_author": "- Truong Thanh Dat, Hutech University, English Club Member",
  "non_profit_impact_title": "Our Achievements and Impact",
  "non_profit_meta_description": "Explore IVS JSC's non-profit activities and community contributions, including projects like 'Let's Talk', English Club, and more.",
  "non_profit_meta_keywords": "IVS JSC, Non-profit, Community activities, Let's Talk, English Club, Social responsibility, Community education",
  "non_profit_mission_desc": "At IVS JSC, we believe that education is the key to a better future. In addition to our business activities, we are committed to actively contributing to society through non-profit projects, aiming to spread knowledge, skills, and create sustainable values for the community.",
  "non_profit_mission_title": "IVS JSC's Community Mission",
  "non_profit_ngo_cooperation_desc": "We actively cooperate with domestic and international non-governmental organizations to implement community development projects, raise awareness about social and environmental issues.",
  "non_profit_ngo_cooperation_title": "Cooperation with Non-Governmental Organizations (NGOs)",
  "non_profit_page_title": "Non-profit & Community Activities - IVS JSC",
  "non_profit_project_say_desc": "An initiative to encourage open communication, sharing stories, and listening. The project creates a safe space for people to express themselves, connect, and support each other within the community.",
  "non_profit_project_say_title": "Project \"Let's Talk\"",
  "non_profit_public_health_desc": "IVS JSC also participates in initiatives to improve community health, organizing free consultations, health check-ups, and providing useful medical information to the public.",
  "non_profit_public_health_title": "Community Health Initiatives",
  "non_profit_steam_global_challenges_desc": "STEAM education projects focused on addressing global issues such as climate change, renewable energy, and public health. We encourage students to develop creative thinking, problem-solving skills, and present their ideas in English.",
  "non_profit_steam_global_challenges_info": "Join our upcoming STEAM competitions and summer camps.",
  "non_profit_steam_global_challenges_title": "STEAM for Global Challenges",

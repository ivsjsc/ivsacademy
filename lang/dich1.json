  "lifeskills_pillar1_desc": "Lifeskills pillar1 desc",
  "lifeskills_pillar1_title": "Lifeskills pillar1 title",
  "lifeskills_pillar2_desc": "Lifeskills pillar2 desc",
  "lifeskills_pillar2_title": "Lifeskills pillar2 title",
